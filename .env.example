# ═══════════════════════════════════════════════════════
# AutoApply Agent — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///autoapply.db
# PostgreSQL (production — used by docker-compose):
# DATABASE_URL=postgresql+asyncpg://autoapply:changeme@localhost:5432/autoapply

# ── Anthropic (Required) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Job Board APIs ───────────────────────────────────
# Adzuna (free: https://developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# RapidAPI (free tier: https://rapidapi.com)
# Same key works for JSearch, LinkedIn API, Active Jobs, Jobs Search
JSEARCH_API_KEY=

# ── Optional ─────────────────────────────────────────
# Backblaze B2 (resume/screenshot archive)
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=autoapply-archive

# CAPTCHA solver (CapSolver)
CAPSOLVER_API_KEY=

# Proxy for scraping
PROXY_URL=

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Docker compose DB password
DB_PASSWORD=changeme

# ── App Settings ─────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
